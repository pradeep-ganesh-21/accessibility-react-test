{
  "name": "hyland-frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "a11y-scout": "file:../a11y-scanner/distribution/a11y-scout-0.1.0.tgz",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "a11y:scan": "a11y-scout scan-repo . --level AA",
    "a11y:scan:strict": "a11y-scout scan-repo . --level AAA"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
